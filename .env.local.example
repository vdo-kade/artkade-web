# Copy this file to .env.local and fill in the values from your Supabase project
# (Project Settings -> API in the Supabase dashboard).
# Never commit .env.local to git -- it's already in .gitignore below.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Only used in server-side admin actions (approving orders, etc).
# Keep this OUT of anything client-side. Never expose it in the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Shared secret checked by app/api/cron/expire-popups/route.ts against the
# incoming request's Authorization: Bearer header. Set this in Vercel's
# project env vars too -- Vercel Cron then attaches it automatically, so
# only Vercel's own cron invoker (not the public internet) can trigger it.
CRON_SECRET=a-long-random-string

# Password for the site-wide splash gate (app/gate) that sits in front of
# the whole live site pre-launch. Compared server-side only in a Server
# Action -- never sent to or checked by the client. Set this in Vercel's
# project env vars too before deploying.
SITE_GATE_PASSWORD=a-password-for-the-splash-gate
