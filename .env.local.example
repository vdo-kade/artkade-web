# Copy this file to .env.local and fill in the values from your Supabase project
# (Project Settings -> API in the Supabase dashboard).
# Never commit .env.local to git -- it's already in .gitignore below.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Only used in server-side admin actions (approving orders, etc).
# Keep this OUT of anything client-side. Never expose it in the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
