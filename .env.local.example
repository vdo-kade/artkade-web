# Copy this file to .env.local and fill in the values from your Supabase project
# (Project Settings -> API in the Supabase dashboard).
# Never commit .env.local to git -- it's already in .gitignore below.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Only used in server-side admin actions (approving orders, etc).
# Keep this OUT of anything client-side. Never expose it in the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Shared secret checked by both app/api/cron/expire-popups/route.ts and
# app/api/cron/cleanup-payment-proofs/route.ts against the incoming
# request's Authorization: Bearer header. Set this in Vercel's project env
# vars too -- Vercel Cron then attaches it automatically, so only Vercel's
# own cron invoker (not the public internet) can trigger either one.
CRON_SECRET=a-long-random-string

# Password for the site-wide splash gate (app/gate) that sits in front of
# the whole live site pre-launch. Compared server-side only in a Server
# Action -- never sent to or checked by the client. Set this in Vercel's
# project env vars too before deploying.
SITE_GATE_PASSWORD=a-password-for-the-splash-gate

# Transactional email (order approved/rejected -- see lib/email.ts and
# app/admin/orders/actions.ts). Get a key from https://resend.com. Without
# it, approve/reject still work normally -- the email send is skipped with
# a server log, not a failure.
RESEND_API_KEY=re_your_resend_api_key

# artkade.space is a verified sending domain in Resend, so production sends
# from a real address on it. Only override this (e.g. to the shared
# onboarding@resend.dev sender) for local dev against a Resend account/domain
# that isn't verified yet.
RESEND_FROM_EMAIL=Art Kade <orders@artkade.space>

# Optional. Where a customer's reply to either email actually lands.
# Defaults to varshadilan@gmail.com (the same inbox that already handles
# fulfillment -- see app/vendor/label/[orderId]/page.tsx's RETURN_ADDRESS).
RESEND_REPLY_TO_EMAIL=varshadilan@gmail.com
